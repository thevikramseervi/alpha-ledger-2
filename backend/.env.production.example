# Production backend (Railway, Render, Fly, etc.)
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Neon direct connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=verify-full"

# Required in production — use a long random string (openssl rand -hex 32)
API_KEY=

# Your deployed frontend URL (comma-separated if you have preview + production domains)
FRONTEND_URL="https://your-app.vercel.app"

PRISMA_TRANSACTION_TIMEOUT_MS=30000
