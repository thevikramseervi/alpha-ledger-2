# Neon (recommended): use the DIRECT connection string from the Neon console (not pooler).
# Must include SSL. Prefer verify-full for Neon (see pg driver warning about sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=verify-full"

# Local Docker Postgres (alternative):
# DATABASE_URL="postgresql://alpha:alpha_secret@localhost:5432/alpha_ledger?schema=public"

PORT=3001
# Dev defaults to 0.0.0.0 (mobile hotspot/LAN). Production uses 127.0.0.1 unless set.
# HOST=0.0.0.0
# Optional: require x-api-key header on all API routes when set
# API_KEY=your-secret-key
# Extra CORS origins (dev also auto-allows private IPs on port 3000)
FRONTEND_URL="http://localhost:3000"
PRISMA_TRANSACTION_TIMEOUT_MS=30000