# Default for http://localhost:3000 — LAN access auto-uses the same host on port 3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Must match backend API_KEY when the API is protected
# NEXT_PUBLIC_API_KEY=your-secret-key
# Extra hostnames for Next.js HMR when your IP changes (hotspot), comma-separated
# DEV_ALLOWED_ORIGINS=192.168.43.177
